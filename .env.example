# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional — API server port (default 3001)
# GEMINI_API_PORT=3001

# Supabase — required for shared daily puzzles + score saving in production
# Create a project at https://supabase.com, run supabase/migrations/20250615000000_initial.sql
# in the SQL editor, then paste these values into Vercel Environment Variables.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
